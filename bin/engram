#!/bin/bash
# Engram CLI — unified entry point for the 5-layer memory system.
#
# Usage:
#   engram init [path] [--template <name>]
#   engram start "topic"
#   engram end "summary"
#   engram search "query" [--chunks] [--json]
#   engram sync <source> <target> [--dry-run] [--all]
#   engram status
#   engram version
#
# Environment:
#   ENGRAM_HOME     — where engram is installed (default: ~/.engram)
#   ENGRAM_CONFIG   — path to config.toml (default: ~/.config/engram/config.toml)

set -euo pipefail

VERSION="0.7.0"
ENGRAM_HOME="${ENGRAM_HOME:-$HOME/.engram}"
ENGRAM_CONFIG="${ENGRAM_CONFIG:-$HOME/.config/engram/config.toml}"

# Resolve the actual script directory (follow symlinks)
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
BIN_DIR="$SCRIPT_DIR"

usage() {
  cat << 'EOF'
Engram — Persistent 5-layer memory for Claude Code

Usage:
  engram init [path] [--template <name>]   Initialize memory in a project
  engram start "topic"                     Load context at session start
  engram end "summary"                     Write lossless checkpoint
  engram search "query" [--chunks] [--json] Search memory (semantic + keyword)
  engram recall "date query"               Date-aware natural language search
  engram similar [--context "topic"]       Find sessions similar to current work
  engram sync <source> <target> [opts]     Sync knowledge between locations
  engram export [file.tar.gz] [--all]      Export memory for transfer
  engram import <file.tar.gz> [--merge]    Import memory from archive
  engram setup [--ollama|--cache|--qdrant] Prepare new system after import
  engram lint [--fix] [--json]             Find stale, orphan, contradictory content
  engram compound "topic"                  Synthesize scattered knowledge into page
  engram xref [--dry-run]                  Generate cross-reference links
  engram index [--incremental] [--status]  Build/update Qdrant vector index
  engram qdrant <download|start|stop>      Manage Qdrant binary
  engram hooks <install|remove|status>     Manage Claude Code hooks
  engram template <create|list|install>    Manage knowledge templates
  engram lock <file>                       Multi-agent file locking
  engram agent <start|end|list|conflicts>  Multi-agent coordination
  engram web [--port PORT]                 Local web UI for browsing memory
  engram export-obsidian [--output DIR]    Export to Obsidian/Notion vault format
  engram pii <scan|redact> [--json]        PII auto-redaction scanner
  engram diff [DATE1 DATE2] [--last N]     Show changes between checkpoints
  engram forget "topic" [--file PATH]      Mark knowledge as superseded
  engram compact [--older-than DAYS]       Merge old lossless into summaries
  engram status                            Show memory layer stats
  engram version                           Print version

Options:
  --template <name>    Use a template when initializing (e.g., d365, react)
  --chunks             Force chunk-level search even for small files
  --json               Output search results as JSON
  --dry-run            Preview sync without making changes
  --all                Sync all layers (including lossless/active)
  --incremental        Only index new/changed files

Environment:
  ENGRAM_HOME          Installation directory (default: ~/.engram)
  ENGRAM_CONFIG        Config file path (default: ~/.config/engram/config.toml)
EOF
}

case "${1:-}" in
  init)
    shift
    exec "$BIN_DIR/engram-init" "$@"
    ;;
  start)
    shift
    exec "$BIN_DIR/engram-start" "$@"
    ;;
  end)
    shift
    exec "$BIN_DIR/engram-end" "$@"
    ;;
  search)
    shift
    exec python3 "$BIN_DIR/engram-search" "$@"
    ;;
  recall)
    shift
    exec python3 "$BIN_DIR/engram-recall" "$@"
    ;;
  similar)
    shift
    exec python3 "$BIN_DIR/engram-similar" "$@"
    ;;
  lock|unlock)
    # Pass "unlock" as first arg if the command was "unlock"
    if [ "$1" = "unlock" ]; then
        shift
        exec "$BIN_DIR/engram-lock" unlock "$@"
    else
        shift
        exec "$BIN_DIR/engram-lock" "$@"
    fi
    ;;
  agent)
    shift
    exec python3 "$BIN_DIR/engram-agent" "$@"
    ;;
  sync)
    shift
    exec python3 "$BIN_DIR/engram-sync" "$@"
    ;;
  export)
    shift
    exec "$BIN_DIR/engram-export" "$@"
    ;;
  import)
    shift
    exec "$BIN_DIR/engram-import" "$@"
    ;;
  setup)
    shift
    exec "$BIN_DIR/engram-setup" "$@"
    ;;
  index)
    shift
    exec python3 "$BIN_DIR/engram-index" "$@"
    ;;
  qdrant)
    shift
    exec "$BIN_DIR/engram-qdrant" "$@"
    ;;
  status)
    shift
    exec "$BIN_DIR/engram-status" "$@"
    ;;
  lint)
    shift
    exec python3 "$BIN_DIR/engram-lint" "$@"
    ;;
  compound)
    shift
    exec python3 "$BIN_DIR/engram-compound" "$@"
    ;;
  xref)
    shift
    exec python3 "$BIN_DIR/engram-xref" "$@"
    ;;
  hooks)
    shift
    exec "$BIN_DIR/engram-hooks" "$@"
    ;;
  template)
    shift
    exec "$BIN_DIR/engram-template" "$@"
    ;;
  web)
    shift
    exec python3 "$BIN_DIR/engram-web" "$@"
    ;;
  export-obsidian)
    shift
    exec python3 "$BIN_DIR/engram-export-obsidian" "$@"
    ;;
  pii)
    shift
    exec python3 "$BIN_DIR/engram-pii" "$@"
    ;;
  diff)
    shift
    exec python3 "$BIN_DIR/engram-diff" "$@"
    ;;
  forget)
    shift
    exec python3 "$BIN_DIR/engram-forget" "$@"
    ;;
  compact)
    shift
    exec python3 "$BIN_DIR/engram-compact" "$@"
    ;;
  version|--version|-v)
    echo "engram $VERSION"
    ;;
  help|--help|-h|"")
    usage
    ;;
  *)
    echo "engram: unknown command '$1'"
    echo "Run 'engram help' for usage."
    exit 1
    ;;
esac
