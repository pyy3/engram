#!/bin/bash
# Engram Cloud — Upgrade or change your plan.
#
# Usage:
#   engram upgrade            Show current plan and available options
#   engram upgrade pro        Switch to pro plan
#   engram upgrade free       Switch to free plan
#   engram upgrade team       Switch to team plan

set -euo pipefail

CRED_DIR="$HOME/.config/engram"
CRED_FILE="$CRED_DIR/credentials.json"

die() { echo "Error: $*" >&2; exit 1; }

json_val() {
  python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get(sys.argv[1],''))" "$1" 2>/dev/null
}

# Load credentials
[ -f "$CRED_FILE" ] || die "Not logged in. Run 'engram login' first."
SERVER=$(python3 -c "import json,sys; print(json.load(sys.stdin)['server'])" < "$CRED_FILE" 2>/dev/null)
API_KEY=$(python3 -c "import json,sys; print(json.load(sys.stdin)['api_key'])" < "$CRED_FILE" 2>/dev/null)
[ -n "$SERVER" ] && [ -n "$API_KEY" ] || die "Invalid credentials. Run 'engram login' again."

api_get() {
  curl -sf --connect-timeout 5 --max-time 10 \
    "$SERVER$1" \
    -H "Authorization: Bearer $API_KEY"
}

api_post() {
  curl -sf --connect-timeout 5 --max-time 10 \
    -X POST "$SERVER$1" \
    -H "Authorization: Bearer $API_KEY" \
    -H "Content-Type: application/json" \
    -d "$2"
}

# Get current usage/plan
USAGE=$(api_get "/api/v1/billing/usage") || die "Could not reach server at $SERVER"
CURRENT_PLAN=$(echo "$USAGE" | python3 -c "import sys,json; print(json.load(sys.stdin)['plan'])")

show_plans() {
  echo ""
  echo "=== Engram Cloud Plans ==="
  echo ""
  printf "  %-8s  %10s  %10s  %8s  %8s\n" "Plan" "Searches" "Storage" "Stores" "Docs"
  printf "  %-8s  %10s  %10s  %8s  %8s\n" "--------" "----------" "----------" "--------" "--------"
  printf "  %-8s  %10s  %10s  %8s  %8s\n" "free" "10,000/mo" "100 MB" "1" "5,000"
  printf "  %-8s  %10s  %10s  %8s  %8s\n" "pro" "100,000/mo" "5 GB" "10" "50,000"
  printf "  %-8s  %10s  %10s  %8s  %8s\n" "team" "unlimited" "50 GB" "1,000" "500,000"
  echo ""
  echo "  Current plan: $CURRENT_PLAN"
  echo ""
  echo "  Usage: engram upgrade <plan>"
  echo ""
}

PLAN="${1:-}"

if [ -z "$PLAN" ]; then
  show_plans
  exit 0
fi

# Validate plan name
case "$PLAN" in
  free|pro|team) ;;
  *) die "Invalid plan '$PLAN'. Choose: free, pro, team" ;;
esac

if [ "$PLAN" = "$CURRENT_PLAN" ]; then
  echo "Already on the '$PLAN' plan."
  exit 0
fi

show_limits() {
  python3 -c "
import sys, json
r = json.loads(sys.stdin.read())
l = r['limits']
storage_mb = l['max_storage_bytes'] / (1024*1024)
searches = l['max_searches_per_month']
s_str = 'unlimited' if searches > 10**15 else f'{searches:,}'
print(f'  Searches: {s_str}/month')
print(f'  Storage:  {storage_mb:.0f} MB')
print(f'  Stores:   {l[\"max_stores\"]}')
print(f'  Docs:     {l[\"max_docs_per_store\"]:,}/store')
" 2>/dev/null || true
}

open_url() {
  local url="$1"
  if command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$url" 2>/dev/null &
  elif command -v open >/dev/null 2>&1; then
    open "$url" 2>/dev/null &
  else
    echo "  Open this URL in your browser:"
    echo "  $url"
    return
  fi
  echo "  Opening checkout in your browser..."
}

# Downgrade to free — direct API call (no payment needed)
if [ "$PLAN" = "free" ]; then
  BODY="{\"plan\":\"free\"}"
  RESULT=$(api_post "/api/v1/billing/upgrade" "$BODY") || die "Downgrade failed. Server returned an error."
  echo "Plan changed: $CURRENT_PLAN -> free"
  echo "$RESULT" | show_limits
  exit 0
fi

# Paid plan (pro/team) — try checkout endpoint first
BODY="{\"plan\":\"$PLAN\"}"
RESULT=$(api_post "/api/v1/billing/checkout" "$BODY") || die "Checkout failed. Server returned an error."

# Check if we got a Stripe checkout URL or a direct upgrade (dev mode)
CHECKOUT_URL=$(echo "$RESULT" | json_val url)

if [ -n "$CHECKOUT_URL" ]; then
  echo "Upgrading to '$PLAN' via Stripe Checkout..."
  open_url "$CHECKOUT_URL"
  echo ""
  echo "  Complete the payment in your browser."
  echo "  Your plan will be activated automatically once payment succeeds."
else
  # Dev mode — direct plan switch happened
  NEW_PLAN=$(echo "$RESULT" | json_val plan)
  echo "Plan changed: $CURRENT_PLAN -> $NEW_PLAN"
  echo "$RESULT" | show_limits
fi
