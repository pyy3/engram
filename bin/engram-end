#!/bin/bash
# Engram — Write lossless session checkpoint.
#
# Usage: engram end "summary of what was done"
#
# Run this every ~30 minutes during active work. Each call creates a
# self-contained chunk in lossless/ with:
#   - Timestamp and summary
#   - Snapshot of current tasks
#   - List of memory files modified since last chunk
#
# Chunks are immutable after creation (append-only layer).

set -euo pipefail

DATE=$(date +%Y-%m-%d)
TIME=$(date +%H:%M)
TIMESTAMP=$(date +%Y-%m-%d_%H%M)
SUMMARY="${*:-Session checkpoint (no summary provided)}"

MEMORY_ROOT=".claude/memory"
LOSSLESS_DIR="$MEMORY_ROOT/lossless"
LOSSLESS_FILE="$LOSSLESS_DIR/${TIMESTAMP}.md"
TASKS_FILE="$MEMORY_ROOT/active/current-tasks.md"

if [ ! -d "$MEMORY_ROOT" ]; then
  echo "Error: $MEMORY_ROOT not found. Run 'engram init' first."
  exit 1
fi

mkdir -p "$LOSSLESS_DIR"

# Find most recent previous chunk for change detection
LAST_CHUNK=$(find "$LOSSLESS_DIR" -name "*.md" -type f 2>/dev/null | sort | tail -1)

# Build the chunk
{
  echo "# Lossless Chunk — $DATE $TIME"
  echo ""
  echo "## $SUMMARY"
  echo ""

  # Snapshot of current tasks
  if [ -f "$TASKS_FILE" ]; then
    echo "### Tasks Snapshot"
    echo ""
    cat "$TASKS_FILE"
    echo ""
  fi

  # Files modified since last chunk
  CHANGED=""
  for layer in semantic procedural active; do
    layer_dir="$MEMORY_ROOT/$layer"
    if [ -d "$layer_dir" ]; then
      while IFS= read -r f; do
        [ -z "$f" ] && continue
        rel=$(echo "$f" | sed "s|$MEMORY_ROOT/||")
        CHANGED="${CHANGED}- ${rel}\n"
      done < <(
        if [ -n "${LAST_CHUNK:-}" ]; then
          find "$layer_dir" -name "*.md" -newer "$LAST_CHUNK" -type f 2>/dev/null || true
        else
          find "$layer_dir" -name "*.md" -type f 2>/dev/null || true
        fi
      )
    fi
  done

  if [ -n "$CHANGED" ]; then
    echo "### Memory Changed Since Last Chunk"
    echo ""
    echo -e "$CHANGED"
  fi

} > "$LOSSLESS_FILE"

echo "Lossless chunk written: $LOSSLESS_FILE"

# Auto-index into Qdrant if configured and available (background, non-blocking)
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"

# Log usage event (non-blocking, best-effort)
CHUNK_BYTES=$(wc -c < "$LOSSLESS_FILE" 2>/dev/null || echo 0)
if [ -x "$SCRIPT_DIR/engram-log" ] || command -v engram-log >/dev/null 2>&1; then
  python3 "$SCRIPT_DIR/engram-log" end lossless "$LOSSLESS_FILE" "$CHUNK_BYTES" "checkpoint" 2>/dev/null || true
fi
# Non-blocking contradiction check on new lossless content
if [ -x "$SCRIPT_DIR/engram-contradict" ] || [ -f "$SCRIPT_DIR/engram-contradict" ]; then
  python3 "$SCRIPT_DIR/engram-contradict" --check-file "$LOSSLESS_FILE" --quiet 2>/dev/null &
fi

ENGRAM_CONFIG="${ENGRAM_CONFIG:-$HOME/.config/engram/config.toml}"

# Check if vector_db auto_index is enabled (default: index if Qdrant is running)
AUTO_INDEX=true
if [ -f "$ENGRAM_CONFIG" ]; then
  # Check if explicitly disabled
  if grep -q "auto_index.*=.*false" "$ENGRAM_CONFIG" 2>/dev/null; then
    AUTO_INDEX=false
  fi
  # Check if vector_db.enabled is false
  if grep -q "enabled.*=.*false" "$ENGRAM_CONFIG" 2>/dev/null; then
    # Only skip if it's in the [vector_db] section context
    AUTO_INDEX=false
  fi
fi

if [ "$AUTO_INDEX" = true ]; then
  QDRANT_URL="${ENGRAM_QDRANT_URL:-http://127.0.0.1:6333}"
  if curl -s -o /dev/null "$QDRANT_URL/healthz" 2>/dev/null; then
    python3 "$SCRIPT_DIR/engram-index" --incremental >/dev/null 2>&1 &
    echo "Background: updating Qdrant index"
  fi
fi
