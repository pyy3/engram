#!/usr/bin/env python3
"""
Engram Log — Record a usage event to the engram analytics database.

Usage:
  engram log <operation> <layer> <file_path> <bytes> [details]

Operations: start, end, search, read, write
Layers: lossless, semantic, procedural, active (or empty string for none)

Auto-creates DB + table on first call.
Auto-detects project from $PWD.

Database location: $ENGRAM_HOME/engram-usage.db (default: ~/.engram/engram-usage.db)
Falls back to ~/.claude/engram-usage.db if it exists there already.
"""
import os
import sys
import sqlite3
from datetime import datetime, timezone
from pathlib import Path

SCHEMA = """
CREATE TABLE IF NOT EXISTS events (
    id INTEGER PRIMARY KEY,
    timestamp TEXT NOT NULL,
    project TEXT NOT NULL,
    operation TEXT NOT NULL,
    layer TEXT,
    file_path TEXT,
    bytes INTEGER DEFAULT 0,
    tokens_est INTEGER DEFAULT 0,
    details TEXT
);
"""


def get_db_path():
    """Resolve DB path: ENGRAM_HOME first, fall back to legacy ~/.claude/."""
    engram_home = Path(os.environ.get("ENGRAM_HOME", Path.home() / ".engram"))
    primary = engram_home / "engram-usage.db"
    legacy = Path.home() / ".claude" / "engram-usage.db"

    if primary.exists():
        return primary
    if legacy.exists():
        return legacy
    # New install — use ENGRAM_HOME
    primary.parent.mkdir(parents=True, exist_ok=True)
    return primary


def get_db():
    db_path = get_db_path()
    db_path.parent.mkdir(parents=True, exist_ok=True)
    conn = sqlite3.connect(str(db_path))
    conn.execute(SCHEMA)
    conn.commit()
    return conn


def log_event(operation, layer=None, file_path=None, byte_count=0, details=None, project=None):
    """Log a single event. Can be called as library function or via CLI."""
    if project is None:
        project = os.environ.get("ENGRAM_PROJECT", os.getcwd())

    ts = datetime.now(timezone.utc).isoformat()
    tokens_est = byte_count // 4

    conn = get_db()
    conn.execute(
        "INSERT INTO events (timestamp, project, operation, layer, file_path, bytes, tokens_est, details) "
        "VALUES (?, ?, ?, ?, ?, ?, ?, ?)",
        (ts, project, operation, layer or None, file_path or None, byte_count, tokens_est, details or None),
    )
    conn.commit()
    conn.close()


def main():
    args = sys.argv[1:]
    if len(args) < 4:
        print("Usage: engram log <operation> <layer> <file_path> <bytes> [details]")
        print("  layer can be empty string '' for none")
        sys.exit(1)

    operation = args[0]
    layer = args[1] if args[1] else None
    file_path = args[2] if args[2] else None
    try:
        byte_count = int(args[3])
    except ValueError:
        byte_count = 0
    details = " ".join(args[4:]) if len(args) > 4 else None

    log_event(operation, layer, file_path, byte_count, details)


if __name__ == "__main__":
    main()
