#!/bin/bash
# Engram — Load cross-session memory into active context at session start.
#
# Usage: engram start "topic you're working on"
#
# What it does:
#   1. Runs semantic + keyword search for the topic
#   2. Appends current tasks from active layer
#   3. Writes everything to active/context-inject.md
#
# Claude Code reads context-inject.md to understand past work relevant to today.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
DATE=$(date +%Y-%m-%d)
QUERY="${*:-Current project context and recent work}"

CONTEXT_FILE=".claude/memory/active/context-inject.md"

if [ ! -d ".claude/memory" ]; then
  echo "Error: .claude/memory/ not found. Run 'engram init' first."
  exit 1
fi

echo "=== SESSION START $DATE ===" > "$CONTEXT_FILE"
echo "Current date: $DATE" >> "$CONTEXT_FILE"
echo "Topic: $QUERY" >> "$CONTEXT_FILE"

# Semantic + keyword search
echo -e "\n=== Auto-recalled memory (semantic + keyword) ===" >> "$CONTEXT_FILE"
if python3 "$SCRIPT_DIR/engram-search" "$QUERY" >> "$CONTEXT_FILE" 2>/dev/null; then
  :
else
  echo "(Memory search unavailable — Ollama not running or no embeddings yet)" >> "$CONTEXT_FILE"
  # Fallback: show recent lossless entries
  LATEST_LOSSLESS=$(find .claude/memory/lossless -name "*.md" -type f 2>/dev/null | sort | tail -3)
  if [ -n "$LATEST_LOSSLESS" ]; then
    echo "" >> "$CONTEXT_FILE"
    echo "=== Recent session logs (fallback) ===" >> "$CONTEXT_FILE"
    for f in $LATEST_LOSSLESS; do
      echo "--- $(basename "$f") ---" >> "$CONTEXT_FILE"
      head -20 "$f" >> "$CONTEXT_FILE"
      echo "" >> "$CONTEXT_FILE"
    done
  fi
fi

# Append current tasks
echo -e "\n=== Active tasks (Layer 5) ===" >> "$CONTEXT_FILE"
if [ -f .claude/memory/active/current-tasks.md ]; then
  cat .claude/memory/active/current-tasks.md >> "$CONTEXT_FILE"
else
  echo "(No active tasks yet)" >> "$CONTEXT_FILE"
fi

# Surface unresolved contradictions
CONTRADICTIONS_FILE=".claude/memory/semantic/.contradictions.jsonl"
if [ -f "$CONTRADICTIONS_FILE" ]; then
  UNRESOLVED=$(grep -c '"status": "unresolved"' "$CONTRADICTIONS_FILE" 2>/dev/null || echo 0)
  if [ "$UNRESOLVED" -gt 0 ]; then
    echo "" >> "$CONTEXT_FILE"
    echo "=== Unresolved contradictions: $UNRESOLVED ===" >> "$CONTEXT_FILE"
    echo "Run 'engram contradict --list' to review." >> "$CONTEXT_FILE"
  fi
fi

# Surface top open knowledge gaps
GAPS_FILE=".claude/memory/semantic/.gaps.jsonl"
if [ -f "$GAPS_FILE" ]; then
  OPEN_GAPS=$(grep -c '"status": "open"' "$GAPS_FILE" 2>/dev/null || echo 0)
  if [ "$OPEN_GAPS" -gt 0 ]; then
    echo "" >> "$CONTEXT_FILE"
    echo "=== Open knowledge gaps: $OPEN_GAPS ===" >> "$CONTEXT_FILE"
    # Show top 3 most-searched gaps
    GAPS_FILE="$GAPS_FILE" python3 -c "
import json, sys, os
gaps = []
for line in open(os.environ['GAPS_FILE']):
    try:
        g = json.loads(line.strip())
        if g.get('status') == 'open':
            gaps.append(g)
    except: pass
gaps.sort(key=lambda g: g.get('times_searched', 1), reverse=True)
for g in gaps[:3]:
    print(f\"  - '{g['query']}' (searched {g.get('times_searched',1)}x)\")
" >> "$CONTEXT_FILE" 2>/dev/null || true
    echo "Run 'engram gaps' for full list." >> "$CONTEXT_FILE"
  fi
fi

# Usage analytics
echo ""
echo "=== Memory Stats ==="

# Local stats
LOCAL_FILES=$(find .claude/memory -name "*.md" -type f 2>/dev/null | wc -l)
LOCAL_SIZE=$(du -sh .claude/memory 2>/dev/null | cut -f1)
LOSSLESS_COUNT=$(find .claude/memory/lossless -name "*.md" -type f 2>/dev/null | wc -l)
SEMANTIC_COUNT=$(find .claude/memory/semantic -name "*.md" -type f 2>/dev/null | wc -l)
PROCEDURAL_COUNT=$(find .claude/memory/procedural -name "*.md" -type f 2>/dev/null | wc -l)
echo "  Local:  ${LOCAL_FILES} files (${LOCAL_SIZE}) — ${SEMANTIC_COUNT} semantic, ${PROCEDURAL_COUNT} procedural, ${LOSSLESS_COUNT} lossless"

# Cloud stats (non-blocking, skip if not linked)
CLOUD_CONFIG=".claude/memory/.engram-cloud.json"
CREDS_FILE="$HOME/.config/engram/credentials.json"
if [ -f "$CLOUD_CONFIG" ] && [ -f "$CREDS_FILE" ]; then
  SERVER=$(python3 -c "import json,sys; print(json.load(sys.stdin)['server'])" < "$CREDS_FILE" 2>/dev/null)
  API_KEY=$(python3 -c "import json,sys; print(json.load(sys.stdin)['api_key'])" < "$CREDS_FILE" 2>/dev/null)
  STORE_ID=$(python3 -c "import json,sys; print(json.load(sys.stdin)['store_id'])" < "$CLOUD_CONFIG" 2>/dev/null)
  STORE_NAME=$(python3 -c "import json,sys; print(json.load(sys.stdin)['store_name'])" < "$CLOUD_CONFIG" 2>/dev/null)
  if [ -n "$SERVER" ] && [ -n "$API_KEY" ]; then
    USAGE=$(curl -sf --connect-timeout 2 --max-time 5 \
      "$SERVER/api/v1/billing/usage" \
      -H "Authorization: Bearer $API_KEY" 2>/dev/null)
    if [ -n "$USAGE" ]; then
      echo "$USAGE" | python3 -c "
import json, sys
u = json.load(sys.stdin)
plan = u['plan']
usage = u['usage']
limits = u['limits']
storage_mb = usage['storage_bytes'] / (1024*1024)
max_mb = limits['max_storage_bytes'] / (1024*1024)
print(f'  Cloud:  {plan} plan — {usage[\"searches\"]}/{limits[\"max_searches_per_month\"]} searches, {storage_mb:.1f}/{max_mb:.0f} MB, {usage[\"syncs\"]} syncs')
" 2>/dev/null || echo "  Cloud:  connected (stats unavailable)"
    else
      echo "  Cloud:  offline"
    fi
  fi
else
  echo "  Cloud:  not linked (run 'engram login && engram link')"
fi

echo ""
echo "Context loaded: $CONTEXT_FILE"
echo "Memory layers ready. Start working!"
