#!/bin/bash
# Engram Import — restore memory from an export archive.
#
# Usage:
#   engram import my-backup.tar.gz              # import into current project
#   engram import my-backup.tar.gz --merge      # merge with existing (default)
#   engram import my-backup.tar.gz --replace    # replace existing memory
#
# Behavior:
#   --merge (default): new files are added, existing files are kept unless
#                      the imported version is newer (by content, not mtime)
#   --replace:         wipes semantic/ procedural/ active/ and replaces with archive
#
# After import:
#   - Embedding cache rebuilds automatically on next search (~5-30s)
#   - Run 'engram start "topic"' to load context

set -euo pipefail

MEMORY_ROOT=".claude/memory"

usage() {
  echo "Usage: engram import <archive.tar.gz> [--merge|--replace]"
  echo ""
  echo "Options:"
  echo "  --merge    Merge with existing memory (default — keeps your files)"
  echo "  --replace  Replace all memory layers with archive contents"
  echo ""
  echo "After import, run: engram start \"your topic\""
}

# Parse args
ARCHIVE=""
MODE="merge"
for arg in "$@"; do
  case "$arg" in
    --merge) MODE="merge" ;;
    --replace) MODE="replace" ;;
    --help|-h) usage; exit 0 ;;
    *) ARCHIVE="$arg" ;;
  esac
done

if [ -z "$ARCHIVE" ]; then
  usage
  exit 1
fi

if [ ! -f "$ARCHIVE" ]; then
  echo "Error: file not found: $ARCHIVE"
  exit 1
fi

# Verify it's a valid archive
if ! tar -tzf "$ARCHIVE" >/dev/null 2>&1; then
  echo "Error: not a valid tar.gz archive: $ARCHIVE"
  exit 1
fi

# Check if it contains engram memory structure
if ! tar -tzf "$ARCHIVE" | grep -q ".claude/memory/"; then
  echo "Error: archive does not contain .claude/memory/ structure."
  echo "This doesn't look like an engram export."
  exit 1
fi

# Initialize if needed
if [ ! -d "$MEMORY_ROOT" ]; then
  echo "Memory not initialized. Creating structure..."
  mkdir -p "$MEMORY_ROOT"/{active,semantic,procedural,lossless}
fi

# Import based on mode
if [ "$MODE" = "replace" ]; then
  echo "Mode: replace (wiping existing memory layers)"
  echo ""

  # Remove existing layers (keep .cache — it'll be invalidated anyway)
  for layer in semantic procedural active lossless; do
    if [ -d "$MEMORY_ROOT/$layer" ]; then
      rm -rf "$MEMORY_ROOT/$layer"
    fi
  done

  # Extract
  tar -xzf "$ARCHIVE" 2>/dev/null
  echo "Extracted archive contents."

else
  # Merge mode
  echo "Mode: merge (adding new files, keeping existing)"
  echo ""

  # Extract to temp dir first
  TEMP_DIR=$(mktemp -d)
  tar -xzf "$ARCHIVE" -C "$TEMP_DIR" 2>/dev/null

  IMPORTED_MEMORY="$TEMP_DIR/.claude/memory"
  if [ ! -d "$IMPORTED_MEMORY" ]; then
    # Try without .claude prefix (some archives might be structured differently)
    IMPORTED_MEMORY="$TEMP_DIR"
  fi

  NEW=0
  SKIPPED=0

  for layer in semantic procedural active lossless; do
    src_dir="$IMPORTED_MEMORY/$layer"
    tgt_dir="$MEMORY_ROOT/$layer"

    if [ ! -d "$src_dir" ]; then
      continue
    fi

    mkdir -p "$tgt_dir"

    while IFS= read -r src_file; do
      [ -z "$src_file" ] && continue
      rel_path="${src_file#$src_dir/}"
      tgt_file="$tgt_dir/$rel_path"

      if [ ! -f "$tgt_file" ]; then
        # New file — copy it
        mkdir -p "$(dirname "$tgt_file")"
        cp "$src_file" "$tgt_file"
        echo "  + $layer/$rel_path"
        NEW=$((NEW + 1))
      else
        SKIPPED=$((SKIPPED + 1))
      fi
    done < <(find "$src_dir" -type f 2>/dev/null)
  done

  rm -rf "$TEMP_DIR"

  echo ""
  echo "Merge complete: $NEW new files, $SKIPPED existing (kept)"
fi

# Invalidate embedding cache (will rebuild on next search)
if [ -d "$MEMORY_ROOT/.cache" ]; then
  rm -rf "$MEMORY_ROOT/.cache"
  echo ""
  echo "Embedding cache cleared (will rebuild on next search)"
fi

# Report final state
echo ""
echo "Memory state after import:"
for layer in semantic procedural active lossless; do
  if [ -d "$MEMORY_ROOT/$layer" ]; then
    count=$(find "$MEMORY_ROOT/$layer" -type f 2>/dev/null | wc -l)
    printf "  %-12s %d files\n" "$layer/" "$count"
  fi
done

echo ""
echo "Next steps:"
echo "  engram start \"your topic\"    # load context"
echo "  engram search \"test query\"   # verify search works (rebuilds cache)"
